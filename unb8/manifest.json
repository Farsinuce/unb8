{
  "manifest_version": 3,
  "name": "unb8",
  "version": "1.2.8",
  "minimum_chrome_version": "121",
  "description": "Replaces clickbait headlines with factual ones using AI.",
  "permissions": [
    "storage",
    "offscreen",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.ekstrabladet.dk/*",
    "https://*.bt.dk/*",
    "https://*.dr.dk/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["parser.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "unb8.chill976@passmail.net",
      "strict_min_version": "128.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "unb8 Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.ekstrabladet.dk/*",
        "https://*.bt.dk/*",
        "https://*.dr.dk/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}