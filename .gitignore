# Original extension kept locally for reference only — not part of this fork
unbait-original/

# Local dev / handover / work docs — kept locally, not needed by extension users.
# Ignore all root-level .md/.txt work files; README.md and BUILD.md are the only
# two users need, so keep those tracked.
/*.md
/*.txt
!/README.md
!/BUILD.md
dr_article.html

# Build artifacts — unsigned / intermediate bundles (rebuilt on demand)
*.xpi
web-ext-artifacts/
# ...but DO track the published, signed release users download
!dist/*.xpi

# web-ext signing state (local tooling cache, not part of the extension)
.amo-upload-uuid

# Local signing helper + AMO API credentials — NEVER commit these
sign.local.ps1
.amo-credentials

# Editor / workspace files
unbait2.code-workspace
